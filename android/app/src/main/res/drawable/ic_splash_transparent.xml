<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ splash icon — must be 288dp x 288dp to be accepted.
     Fully transparent so NOTHING is drawn on the splash background.
     Combined with windowSplashScreenIconBackgroundColor = splash_color,
     the result is a plain solid pink screen with zero visible icon.     -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="288dp"
    android:height="288dp"
    android:viewportWidth="288"
    android:viewportHeight="288">
    <!-- No paths = fully transparent drawable -->
</vector>
